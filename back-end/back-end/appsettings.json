{
    "Database": {
        "Tables": {
            "Validation": {
                "Title": {
                    "NameMaxLength": 255,
                    "SynopsisMaxLength": 5000,
                    "ImgMaxLength": 500
                },
                "ChapterTranslation": {
                    "ChapterTitleMaxLength": 255
                },
                "Page": {
                    "ImageUrlMaxLength": 500
                },
                "AlternativeName": {
                    "ValueMaxLength": 500
                }
            }
        }
    },
    "CacheSettings": {
        "Static": {
            // Http Header maxage
            "maxage": 86400,
            "key": "static:all"
        }
    },
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.Hosting.Lifetime": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        // Used to connect with the redis.
        "Redis": "redis:6379",
        // Used to connect with the database at the terminal.
        "Terminal": "Host=localhost;Port=5433;Database=CatManga;Username=root;Password=postgreSQL",
        // Used to connect with the database in Docker (containers)
        "Default": "Host=db;Port=5432;Database=CatManga;Username=root;Password=postgreSQL"
    }
}
