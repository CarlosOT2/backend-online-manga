{
    "Database": {
        "Tables": {
            "Validation": {
                "Title": {
                    "NameMaxLength": 255,
                    "SynopsisMaxLength": 5000,
                    "ImgMaxLength": 500
                },
                "ChapterTranslation": {
                    "ChapterTitleMaxLength": 255
                },
                "Page": {
                    "ImageUrlMaxLength": 500
                },
                "AlternativeName": {
                    "ValueMaxLength": 500
                }
            }
        }
    },
    "CacheSettings": {
        "Static": {
            // Http Header maxage
            "maxage": 86400,
            "key": "static:all"
        }
    },
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.Hosting.Lifetime": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
        }
    },
    "AllowedHosts": "*"
}
